@model Student
<h2>Edit Student Form Version 01</h2>
<form method="get" action="/Student/SaveEdit/@Model.Id">
    <div>
        <label for="Name">Name</label>
        <input type="text" id="Name" name="Name" value="@Model.Name" class="form-control" />
    </div>
    <div>
        <label for="Address">Address</label>
        <input type="text" id="Address" name="Address" value="@Model.Address" class="form-control" />
    </div>
    <div>
        <label for="Name">Department</label>
        <select id="Department" name="DepartmentId" class="form-control">
            @foreach (var item in ViewBag.data)
            {
                if (Model.Department.Id == item.Id)
                {
                    <option selected value="@item.Id">@item.Name</option>
                }
                else
                {
                    <option value="@item.Id">@item.Name</option>
                }
            }
        </select>
    </div>
    <div>
        <input type="submit" value="Edit" class="btn btn-primary mt-2" />
    </div>
</form>