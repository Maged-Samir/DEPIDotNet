<table class="table table-bordered table-hover table-striped">
    <thead>
        <tr>
            <th scope="col">ID</th>
            <th scope="col">Name</th>
            <th scope="col">QTY</th>
            <th scope="col">Description</th>
            <th scope="col">Price</th>

        </tr>
    </thead>
    <tbody>
      @foreach(var item in Model)
        {
            <tr>
                <th scope="row">@item.Id</th>
                <td>@item.Name</td>
                <td>@item.Qty</td>
                <td>@item.Description</td>
                <td>@item.Price</td>

            </tr>
        }

    </tbody>
</table>