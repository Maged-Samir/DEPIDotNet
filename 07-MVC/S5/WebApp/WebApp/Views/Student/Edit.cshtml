@model Student

<h2>Student Version01</h2>

<form method="get" action="/Student/SaveEdit/@Model.Id">

    <div class="row">

        <div class="col-4">
            <label for="Name">Name</label>
            <input type="Text" id="Name" name="Name" value="@Model.Name" class="form-control" />
        </div>
        <div class="col-4">
            <label for="Address">Address</label>
            <input type="Text" id="Address" name="Address" value="@Model.Address" class="form-control" />
        </div>
        <div class="col-4">
            <label for="Grade">Grade</label>
            <input type="Text" id="Grade" name="Grade" value="@Model.Grade" class="form-control" />
        </div>
        <div class="col-4">
            <label for="Division">Division</label>
            <input type="Text" id="Division" name="Division" value="@Model.Division" class="form-control" />
        </div>
        <div class="col-4">
            <label for="DepartmentId">DepartmentId</label>
            <select name="DepartmentId" class="form-control">
                @foreach (var item in ViewBag.data)
                {
                    if (Model.DepartmentId == item.Id)
                    {
                        <option selected value="@item.Id">@item.Name</option>
                    }
                    else
                    {
                        <option value="@item.Id">@item.Name</option>
                    }
                  
                }
            </select>
        </div>
        <div>
            <input type="submit" value="Save" class="btn btn-primary mt-2" />
        </div>
    </div>

</form>