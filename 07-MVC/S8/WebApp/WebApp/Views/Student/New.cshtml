@model Student

<h2>Add New Student</h2>
<form method="post" action="/Student/SaveNew">

    @Html.AntiForgeryToken()

    <div class="col">
        <label for="Name">Name</label>
        <input type="text" id="Name" name="Name" class="form-control" />
    </div>
    <div class="col">
        <label for="Age">Age</label>
        <input type="text" id="Age" name="Age" value="@Model.Age" class="form-control" />
    </div>
    <div class="col">
        <label for="Division">Division</label>
        <input type="text" id="Division" name="Division" value="@Model.Division" class="form-control" />
    </div>
    <div class="col">
        <label for="Grade">Grade</label>
        <input type="text" id="Grade" name="Grade" value="@Model.Grade" class="form-control" />
    </div>
    @* <div class="col">
        <label for="Department">Department</label>
        <input type="text" id="Department" name="DepartmentId" class="form-control" />
    </div> *@
    <div class="col">
        <label for="Department">Department</label>
        <select id="Department" name="DepartmentId" class="form-control">
            @foreach (var item in ViewBag.data)
            {
                <option value="@item.Id">@item.Name</option>
            }
        </select>
    </div>
    <div>
        <input type="submit" value="Save" class="btn btn-primary mt-2" />
    </div>

</form>